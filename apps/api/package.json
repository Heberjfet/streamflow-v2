{
  "name": "@streamflow/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@fastify/cors": "^9.0.0",
    "@fastify/jwt": "^8.0.0",
    "@fastify/multipart": "^8.0.0",
    "@fastify/passport": "^2.0.0",
    "@fastify/static": "^7.0.0",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.0.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.36.0",
    "fastify": "^4.28.0",
    "google-auth-library": "^9.0.0",
    "ioredis": "^5.3.2",
    "postgres": "^3.4.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.28.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
