# ===========================================
# StreamFlow v2 - Environment Configuration
# ===========================================

# Server
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://streamflow:streamflow@localhost:5432/streamflow

# Redis
REDIS_URL=redis://localhost:6379

# S3/MinIO
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=streamflow
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_BASE_URL=http://localhost:9000/streamflow
S3_FORCE_PATH_STYLE=true

# JWT Authentication
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/v1/auth/callback

# Frontend URL (for CORS and OAuth)
FRONTEND_URL=http://localhost:3000

# CORS
CORS_ORIGIN=http://localhost:3000

# Worker Configuration
WORKER_CONCURRENCY=2
