{
  "name": "streamflow-v2",
  "version": "1.0.0",
  "private": true,
  "description": "Plataforma de Video Self-Hosted para streaming personal",
  "workspaces": [
    "apps/*",
    "packages/*",
    "worker",
    "frontend"
  ],
  "scripts": {
    "dev": "npm run dev --workspaces --if-present",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:worker": "npm run dev --workspace=worker",
    "dev:frontend": "npm run dev --workspace=frontend",
    "build": "npm run build --workspaces --if-present",
    "build:api": "npm run build --workspace=apps/api",
    "build:worker": "npm run build --workspace=worker",
    "build:frontend": "npm run build --workspace=frontend",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "db:generate": "npm run db:generate --workspace=packages/db",
    "db:migrate": "npm run db:migrate --workspace=packages/db",
    "db:push": "npm run db:push --workspace=packages/db",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules worker/node_modules"
  },
  "keywords": [
    "video",
    "streaming",
    "hls",
    "self-hosted",
    "transcoding"
  ],
  "author": "HeberJFet",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}